                <td class="py-4 px-4">2/3</td>
              </tr>
              <tr class="hover:bg-[var(--color-graphite)]/20 transition-colors">
                <td class="py-4 px-4 text-[var(--color-ivory)]">Blanco</td>
                <td class="py-4 px-4">Pequeña, apertura abierta</td>
                <td class="py-4 px-4">Albariño, Verdejo, Sauvignon Blanc, Rosado</td>
                <td class="py-4 px-4">1/3</td>
              </tr>
            </tbody>
          </table>
        </div>

        <figure class="mb-8">
          <div class="aspect-[16/9] overflow-hidden rounded-sm relative">
            <img src="/images/blog/articulo-cata/experiencia-cata.png" alt="Pareja disfrutando de una cata de vino en el salón de su hogar junto a la vinoteca con iluminación ambiental cálida y copas de sumiller" class="w-full h-full object-cover hover:scale-105 transition-transform duration-[2s]" loading="lazy" decoding="async" />
