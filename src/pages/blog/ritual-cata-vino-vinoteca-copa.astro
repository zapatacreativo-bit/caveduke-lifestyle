                <td class="py-4 px-4">Pinot Noir, Nebbiolo, Garnacha elegante</td>
                <td class="py-4 px-4">1/4</td>
              </tr>
              <tr class="border-b border-[var(--color-silver)]/10 hover:bg-[var(--color-graphite)]/20 transition-colors">
                <td class="py-4 px-4 text-[var(--color-ivory)]">Universal</td>
                <td class="py-4 px-4">Tulipa media, versátil</td>
                <td class="py-4 px-4">Tintos jóvenes, blancos con cuerpo</td>
                <td class="py-4 px-4">1/3</td>
              </tr>
              <tr class="border-b border-[var(--color-silver)]/10 hover:bg-[var(--color-graphite)]/20 transition-colors">
