---
// src/components/Blog.astro

const posts = [
  {
    title: "Cómo Elegir la Vinoteca Perfecta para Tu Hogar",
    excerpt: "Guía definitiva para seleccionar dimensiones, materiales y prestaciones según tu espacio y colección. De la madera noble al acero inoxidable.",
    img: "/images/blog/bodega-lujo.png",
    date: "8 Mar 2026",
    category: "Guías",
    readTime: "7 min",
    link: "/blog/como-elegir-vinoteca-perfecta",
  },
  {
    title: "Diseño a Medida: El Arte de Integrar una Vinoteca en tu Arquitectura",
    excerpt: "Descubre cómo nuestros diseñadores crean vinotecas que se funden con el mobiliario existente, respetando cada línea del espacio.",
    img: "/images/blog/diseno-medida.png",
    date: "2 Mar 2026",
    category: "Diseño",
    readTime: "5 min",
    link: "/blog/diseno-a-medida-vinoteca",
  },
  {
    title: "Temperatura y Humedad: Los Secretos de la Conservación del Vino",
    excerpt: "La ciencia detrás del almacenamiento perfecto: por qué el 65% de humedad y los 14°C son el estándar dorado de la enología.",
    img: "/images/blog/conservacion-vino.png",
    date: "24 Feb 2026",
    category: "Enología",
    readTime: "6 min",
    link: "/blog/temperatura-humedad-conservacion-vino",
  },
  {
    title: "Tendencias 2026: El Futuro de las Vinotecas de Lujo",
    excerpt: "Desde el minimalismo escultórico hasta la integración domótica, estas son las tendencias que están redefiniendo el sector premium.",
    img: "/images/blog/tendencias-vinotecas.png",
    date: "18 Feb 2026",
    category: "Tendencias",
    readTime: "8 min",
    link: "/blog/tendencias-2026-vinotecas-lujo",
  },
  {
    title: "Tecnología Silenciosa: La Ingeniería Detrás del Silencio Caveduke",
    excerpt: "Compresión amortiguada, cristal Climalit y sensores inteligentes. La revolución tecnológica que protege cada botella.",
    img: "/images/blog/tecnologia-vino.png",
    date: "10 Feb 2026",
    category: "Innovación",
    readTime: "6 min",
    link: "/blog/tecnologia-silenciosa-ingenieria-caveduke",
  },
  {
    title: "El Ritual de la Cata: Preparar el Vino Desde la Vinoteca a la Copa",
    excerpt: "Los sumilleres más prestigiosos comparten su protocolo para extraer, decantar y servir un gran reserva en condiciones óptimas.",
    img: "/images/blog/cata-vinos.png",
    date: "3 Feb 2026",
    category: "Lifestyle",
    readTime: "5 min",
    link: "/blog/ritual-cata-vino-vinoteca-copa",
  },
];
---

<section id="blog" class="bg-[var(--color-noir)] py-32 overflow-hidden border-t border-[var(--color-silver)]/10 scroll-mt-20">
  <div class="max-w-7xl mx-auto px-6 md:px-12">

    <!-- Section Header -->
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-8 mb-20 blog-header">
      <div>
        <div class="flex items-center gap-4 mb-6">
          <div class="w-8 h-px bg-[var(--color-gold)]"></div>
          <p class="font-accent text-[var(--color-gold)] tracking-widest uppercase text-sm">Journal</p>
        </div>
        <h2 class="font-display text-4xl md:text-6xl text-[var(--color-ivory)] leading-tight">
          El Mundo del <br/>
          <span class="italic text-[var(--color-silver)]/50">Vino & Diseño</span>
        </h2>
      </div>
      <p class="font-body text-[var(--color-silver)]/60 text-sm md:text-base max-w-md leading-relaxed">
        Noticias, tendencias y reflexiones desde el corazón de la cultura vinícola y el diseño de alta gama.
      </p>
    </div>

    <!-- Blog Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 md:gap-10">
      {posts.map((post, index) => (
        <a href={post.link} class="group relative flex flex-col blog-card cursor-pointer no-underline">
          
          <!-- Image Container -->
          <div class="relative aspect-[4/3] overflow-hidden rounded-sm mb-6 bg-[var(--color-graphite)]/30">
            <img 
              src={post.img} 
              alt={post.title}
              class="relative z-[1] w-full h-full object-cover transition-transform duration-[1200ms] ease-out group-hover:scale-110"
              loading="lazy"
              decoding="async"
            />
            <!-- Gradient overlay -->
            <div class="absolute inset-0 z-[2] bg-gradient-to-t from-[var(--color-noir)]/80 via-transparent to-transparent pointer-events-none"></div>
            
            <!-- Gold shimmer on hover -->
            <div class="absolute inset-0 z-[3] opacity-0 group-hover:opacity-100 transition-opacity duration-700 pointer-events-none bg-gradient-to-tr from-transparent via-[var(--color-gold)]/5 to-transparent"></div>

            <!-- Category Badge -->
            <div class="absolute top-4 left-4 z-[5]">
              <span class="bg-[var(--color-gold)] text-[var(--color-noir)] font-accent text-[10px] tracking-[0.2em] uppercase px-3 py-1.5 rounded-sm">
                {post.category}
              </span>
            </div>

            <!-- Hover border -->
            <div class="absolute inset-0 z-[4] border border-[var(--color-silver)]/0 group-hover:border-[var(--color-gold)]/20 transition-colors duration-700 pointer-events-none m-3"></div>
          </div>

          <!-- Content -->
          <div class="flex flex-col flex-grow">
            <!-- Meta -->
            <div class="flex items-center gap-3 mb-4">
              <span class="font-accent text-[var(--color-gold)]/60 text-[11px] tracking-[0.15em] uppercase">{post.date}</span>
              <span class="w-1 h-1 rounded-full bg-[var(--color-gold)]/40"></span>
              <span class="font-accent text-[var(--color-silver)]/40 text-[11px] tracking-[0.15em] uppercase">{post.readTime} lectura</span>
            </div>

            <!-- Title -->
            <h3 class="font-display text-xl md:text-2xl text-[var(--color-ivory)] leading-snug mb-3 group-hover:text-[var(--color-gold)] transition-colors duration-500">
              {post.title}
            </h3>

            <!-- Excerpt -->
            <p class="font-body text-sm text-[var(--color-silver)]/60 leading-relaxed mb-6 flex-grow">
              {post.excerpt}
            </p>

            <!-- Read More Link -->
            <div class="flex items-center gap-2 text-[var(--color-gold)] font-accent tracking-widest text-xs uppercase opacity-70 group-hover:opacity-100 group-hover:gap-4 transition-all duration-500">
              <span>Leer Artículo</span>
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M5 12h14"/>
                <path d="m12 5 7 7-7 7"/>
              </svg>
            </div>
          </div>

          <!-- Decorative bottom line that expands on hover -->
          <div class="absolute bottom-0 left-0 w-0 h-px bg-[var(--color-gold)]/40 group-hover:w-full transition-all duration-700 ease-out"></div>
        </a>
      ))}
    </div>

    <!-- View All Button -->
    <div class="flex justify-center mt-20 blog-cta">
      <a href="#" class="premium-button">
        <span>Ver Todos los Artículos</span>
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M5 12h14"/>
          <path d="m12 5 7 7-7 7"/>
        </svg>
      </a>
    </div>

  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  // Animate header
  gsap.fromTo('.blog-header', 
    { y: 50, opacity: 0 },
    {
      y: 0,
      opacity: 1,
      duration: 1,
      ease: 'power3.out',
      scrollTrigger: {
        trigger: '#blog',
        start: 'top 80%'
      }
    }
  );

  // Stagger blog cards
  gsap.fromTo('.blog-card', 
    { y: 80, opacity: 0 },
    {
      y: 0,
      opacity: 1,
      duration: 1,
      stagger: 0.12,
      ease: 'power4.out',
      scrollTrigger: {
        trigger: '.blog-card',
        start: 'top 95%'
      }
    }
  );

  // CTA button
  gsap.fromTo('.blog-cta', 
    { y: 30, opacity: 0 },
    {
      y: 0,
      opacity: 1,
      duration: 0.8,
      ease: 'power3.out',
      scrollTrigger: {
        trigger: '.blog-cta',
        start: 'top 95%'
      }
    }
  );
</script>
